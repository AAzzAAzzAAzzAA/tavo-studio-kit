{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/tavo/schemas/regex-fixture.schema.json",
  "title": "Regex Fixture Suite",
  "type": "object",
  "required": ["name", "rules", "cases"],
  "properties": {
    "name": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pattern", "replacement"],
        "properties": {
          "id": { "type": "string" },
          "pattern": { "type": "string" },
          "replacement": { "type": "string" },
          "flags": { "type": "string" },
          "enabled": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "input", "expected"],
        "properties": {
          "id": { "type": "string" },
          "input": { "type": "string" },
          "expected": { "type": "string" }
        }
      }
    }
  }
}
