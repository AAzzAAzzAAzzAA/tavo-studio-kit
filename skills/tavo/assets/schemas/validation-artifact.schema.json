{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/tavo/schemas/validation-artifact.schema.json",
  "title": "Tavo Validation Run Manifest",
  "type": "object",
  "required": ["case", "status", "startedAt", "artifacts"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "case": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "planned",
        "prepared",
        "running",
        "passed",
        "failed",
        "blocked",
        "failed_runner_or_infrastructure",
        "failed_product_behavior"
      ]
    },
    "startedAt": {
      "type": "string",
      "minLength": 1
    },
    "finishedAt": {
      "type": "string",
      "minLength": 1
    },
    "appVersion": {
      "type": "string"
    },
    "device": {
      "type": "string"
    },
    "evidenceLevel": {
      "enum": [
        "claimed",
        "needs-live-verify",
        "official-current",
        "mcp-runtime",
        "schema-seen",
        "dry-run-pass",
        "roundtrip-pass",
        "semantic-pass",
        "semantic-pass-observation",
        "ui-pass",
        "live-verified",
        "live-verified-regression",
        "semantic-mixed",
        "historical-derived",
        "deprecated"
      ]
    },
    "countsTowardKpi": {
      "type": "boolean"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "progress": {
      "type": "object"
    },
    "retention": {},
    "cleanup": {
      "type": "object"
    },
    "notes": {
      "type": "string"
    }
  },
  "anyOf": [
    {
      "required": ["evidenceLevel"]
    },
    {
      "required": ["countsTowardKpi"]
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["finishedAt"]
      }
    },
    {
      "if": {
        "properties": {
          "countsTowardKpi": {
            "const": true
          }
        },
        "required": ["countsTowardKpi"]
      },
      "then": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": ["finishedAt", "progress"]
      }
    }
  ],
  "additionalProperties": true
}
