{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/tavo/schemas/tpg-manifest.schema.json",
  "title": "Tavo Plugin Manifest 0.92",
  "description": "Schema for a selected plugin-root manifest.json. Root entry wins over the legacy scripts.actions alias.",
  "type": "object",
  "required": ["id", "name", "version"],
  "$defs": {
    "packagePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))\\S(?:.*\\S)?$",
      "description": "Package-relative virtual path using forward slashes; absolute paths, URLs, backslashes, and traversal are forbidden."
    }
  },
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "specVersion": { "type": "integer", "minimum": 1 },
    "entry": {
      "$ref": "#/$defs/packagePath",
      "description": "Preferred plugin runtime entry. When both declarations exist, this field wins."
    },
    "cover": { "$ref": "#/$defs/packagePath" },
    "scripts": {
      "type": "object",
      "properties": {
        "actions": {
          "$ref": "#/$defs/packagePath",
          "deprecated": true,
          "description": "Legacy compatibility alias used only when root entry is absent."
        }
      },
      "additionalProperties": true
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contributes": {
      "type": "object",
      "properties": {
        "inputActions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "icon": { "$ref": "#/$defs/packagePath" }
            },
            "additionalProperties": true
          }
        },
        "sidebar": { "type": "array" },
        "htmlFragments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["src"],
            "properties": {
              "src": { "$ref": "#/$defs/packagePath" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["contributes"],
        "properties": {
          "contributes": {
            "anyOf": [
              {
                "required": ["inputActions"],
                "properties": { "inputActions": { "type": "array", "minItems": 1 } }
              },
              {
                "required": ["sidebar"],
                "properties": { "sidebar": { "type": "array", "minItems": 1 } }
              }
            ]
          }
        }
      },
      "then": {
        "anyOf": [
          { "required": ["entry"] },
          {
            "required": ["scripts"],
            "properties": {
              "scripts": {
                "type": "object",
                "required": ["actions"]
              }
            }
          }
        ]
      }
    }
  ],
  "additionalProperties": true
}
